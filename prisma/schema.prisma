generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  username      String?  @unique
  name          String?
  firstName     String?
  lastName      String?
  email         String   @unique
  emailVerified DateTime?
  password      String?
  image         String?

  isOAuth       Boolean  @default(false)

  isArchived    Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile             UserProfile?
  preferences         UserPreferences?

  errands             Errand[]
  errandMemberships   ErrandMember[]
  expenses            Expense[]

  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
}

model UserProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  phone       String?
  dateOfBirth DateTime?
  occupation  String?
  bio         String?
  
  address     Address?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Address {
  id            String       @id @default(cuid())
  profileId     String       @unique
  profile       UserProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  streetAddress String?      
  city          String?
  state         String?
  country       String?
  postalCode    String?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model UserPreferences {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  currency       Currency  @default(NGN)
  theme          Theme     @default(SYSTEM)
  weekStartsOn   WeekStart @default(MONDAY)
  symbolPosition String    @default("before")
  timezone       String?
  language       String    @default("en")

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expires   DateTime

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expires])
}

model Errand {
  id             String       @id @default(cuid())
  title          String
  description    String?
  amountReceived Decimal      @db.Decimal(12, 2)
  status         ErrandStatus? @default(ACTIVE)
  isArchived     Boolean?      @default(false)
  deletedAt      DateTime?    
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  members        ErrandMember[]
  expenses       Expense[]
  notes          ErrandNote[]     
  activities     ActivityLog[]   
  attachments    Attachment[]     

  @@index([userId, isArchived, status])
}

model ErrandMember {
  id              String     @id @default(cuid())
  errandId        String
  errand          Errand     @relation(fields: [errandId], references: [id], onDelete: Cascade)
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role            ErrandRole @default(COLLABORATOR)

  allocatedBudget Decimal?   @db.Decimal(12, 2) 
  
  joinedAt        DateTime   @default(now())

  @@unique([errandId, userId])
  @@index([userId])
  @@index([errandId])
}

model ErrandNote {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  errandId  String
  errand    Errand   @relation(fields: [errandId], references: [id], onDelete: Cascade)

  @@index([errandId])
}

model ActivityLog {
  id        String          @id @default(cuid())
  type      ActivityLogType
  title     String          
  meta      String?         
  createdAt DateTime        @default(now())

  errandId  String
  errand    Errand          @relation(fields: [errandId], references: [id], onDelete: Cascade)

  @@index([errandId])
}

model Attachment {
  id        String   @id @default(cuid())
  name      String   
  url       String  
  size      Int?     
  createdAt DateTime @default(now())

  errandId  String
  errand    Errand   @relation(fields: [errandId], references: [id], onDelete: Cascade)

  @@index([errandId])
}

model Expense {
  id          String          @id @default(cuid())
  description String
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory @default(OTHER)
  vendor      String?
  receiptUrl  String?
  expenseDate DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  errandId    String
  errand      Errand          @relation(fields: [errandId], references: [id], onDelete: Cascade)
  userId    String?  
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([errandId])
  @@index([userId])
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  
  type        NotificationType
  title       String           
  message     String           
  
  isRead      Boolean          @default(false)
  readAt      DateTime?
  
  actionLabel String?          
  actionRoute String?          
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
  @@index([createdAt])
}

enum ExpenseCategory {
  TRANSPORT
  FOOD
  OFFICE
  UTILITIES
  SHOPPING
  OTHER
}

enum ErrandStatus {
  ACTIVE
  COMPLETED
}

enum ErrandRole {
  OWNER
  COLLABORATOR
  VIEWER
}

enum ActivityLogType {
  SYSTEM         
  CREATE_EXPENSE
  EDIT_EXPENSE
  DELETE_EXPENSE
  ADD_NOTE
  DELETE_NOTE
  COMPLETED
}

enum NotificationType {
  CASH_ALERT    
  ERRAND_STATUS    
  SYSTEM_SECURITY 
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum Currency {
  NGN
  USD
  EUR
  GBP
}

enum WeekStart {
  MONDAY
  SUNDAY
}