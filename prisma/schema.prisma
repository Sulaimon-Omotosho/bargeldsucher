generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String?
  firstName     String?
  lastName      String?
  email         String   @unique
  emailVerified DateTime?
  password      String?
  image         String?

  isOAuth       Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  errands             Errand[]
  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expires   DateTime

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expires])
}

model Errand {
  id             String       @id @default(cuid())
  title          String
  description    String?
  amountReceived Decimal      @db.Decimal(12, 2)
  status         ErrandStatus? @default(ACTIVE)
  isArchived     Boolean?      @default(false)
  deletedAt      DateTime?    
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  expenses       Expense[]
  notes          ErrandNote[]     
  activities     ActivityLog[]   
  attachments    Attachment[]     

  @@index([userId, isArchived, status])
}

model ErrandNote {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  errandId  String
  errand    Errand   @relation(fields: [errandId], references: [id], onDelete: Cascade)

  @@index([errandId])
}

model ActivityLog {
  id        String          @id @default(cuid())
  type      ActivityLogType
  title     String          
  meta      String?         
  createdAt DateTime        @default(now())

  errandId  String
  errand    Errand          @relation(fields: [errandId], references: [id], onDelete: Cascade)

  @@index([errandId])
}

model Attachment {
  id        String   @id @default(cuid())
  name      String   
  url       String  
  size      Int?     
  createdAt DateTime @default(now())

  errandId  String
  errand    Errand   @relation(fields: [errandId], references: [id], onDelete: Cascade)

  @@index([errandId])
}

model Expense {
  id          String          @id @default(cuid())
  description String
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory @default(OTHER)
  vendor      String?
  receiptUrl  String?
  expenseDate DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  errandId    String
  errand      Errand          @relation(fields: [errandId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  
  type        NotificationType
  title       String           
  message     String           
  
  isRead      Boolean          @default(false)
  readAt      DateTime?
  
  actionLabel String?          
  actionRoute String?          
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
  @@index([createdAt])
}

enum ExpenseCategory {
  TRANSPORT
  FOOD
  OFFICE
  UTILITIES
  SHOPPING
  OTHER
}

enum ErrandStatus {
  ACTIVE
  COMPLETED
}

enum ActivityLogType {
  SYSTEM         
  CREATE_EXPENSE
  EDIT_EXPENSE
  DELETE_EXPENSE
  ADD_NOTE
  DELETE_NOTE
  COMPLETED
}

enum NotificationType {
  CASH_ALERT    
  ERRAND_STATUS    
  SYSTEM_SECURITY 
}